# ============================================================
# UGAT TrainTrack — Environment Variables
# Copy this file to .env for local development.
# In Railway, set these in the Railway dashboard under Variables.
# ============================================================

# ----------------------------
# DATABASE (auto-set by Railway MySQL plugin)
# ----------------------------
MYSQLHOST=localhost
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=ugat_db
MYSQLPORT=3306

# ----------------------------
# APPLICATION
# ----------------------------
APP_URL=https://your-app.up.railway.app

# ----------------------------
# EMAIL (Gmail SMTP)
# Get an App Password at: https://myaccount.google.com/apppasswords
# ----------------------------
GMAIL_ADDRESS=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=UGAT Notifications
EMAIL_FROM_ADDRESS=your-gmail@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
EMAIL_ENABLED=true
EMAIL_DEBUG_MODE=false

# ----------------------------
# SMS — UniSMS (primary)
# Get your key at: https://unismsapi.com/
# ----------------------------
SMS_PROVIDER=unisms
UNISMS_API_KEY=sk_your-key-here
UNISMS_API_URL=https://unismsapi.com/api/sms
SMS_ENABLED=true
SMS_DEBUG_MODE=false

# ----------------------------
# SMS — Semaphore (optional backup)
# Get your key at: https://semaphore.co/
# ----------------------------
SEMAPHORE_API_KEY=your-semaphore-key-here
SEMAPHORE_SENDER_NAME=SEMAPHORE

# ----------------------------
# PAYMENT — PayMongo
# Get your keys at: https://dashboard.paymongo.com/
# Use sk_test_* keys for staging, sk_live_* for production
# ----------------------------
PAYMONGO_SECRET_KEY=sk_test_your-key-here
PAYMONGO_WEBHOOK_SECRET=whsk_your-webhook-secret-here
